{
    "name": "backend",
    "version": "1.0.0",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "dev": "node --env-file=.env --watch src/server.ts",
        "start": "node --env-file=.env src/server.ts",
        "check": "tsc",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prisma:generate": "prisma generate",
        "prisma:push": "prisma db push",
        "prisma:studio": "prisma studio",
        "prisma:seed": "prisma db seed",
        "prisma:seed:perf": "npx ts-node prisma/seed-performance.ts",
        "format": "pnpx @biomejs/biome format --write",
        "lint": "pnpx @biomejs/biome lint",
        "lint:fix": "pnpx @biomejs/biome lint --fix",
        "biome:check": "pnpx @biomejs/biome check",
        "biome:check:fix": "pnpx @biomejs/biome check --fix"
    },
    "dependencies": {
        "@prisma/client": "^5.3.1",
        "express": "^5.1.0",
        "express-rate-limit": "^7.5.0",
        "json-2-csv": "^5.5.9",
        "jsonwebtoken": "^9.0.2",
        "zod": "^4.3.5",
        "zod-validation-error": "^5.0.0"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.15",
        "@types/express": "^5.0.3",
        "@types/express-serve-static-core": "^5.0.7",
        "@types/http-errors": "^2.0.5",
        "@types/jsonwebtoken": "^9.0.3",
        "@types/node": "^20.8.2",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-v8": "^4.1.6",
        "prisma": "^5.3.1",
        "supertest": "^7.2.2",
        "typescript": "^5.2.2",
        "vitest": "^4.1.6"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    }
}